# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────

# Supabase — https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Newer Supabase calls this the "Publishable" key (starts with sb_publishable_...)
# Older Supabase called it the "anon/public" key (starts with eyJ...)
# Use whichever one your Supabase dashboard shows — both are supported
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx

# Service Role key — NEVER expose this in the browser (no NEXT_PUBLIC_ prefix)
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# App URL (used for email verification redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
